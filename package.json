{
  "name": "motion-studio",
  "version": "0.1.0",
  "description": "AI-powered motion graphics desktop app — generate animations from text prompts",
  "main": "out/main/index.js",
  "author": "Hanafiii",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "typecheck:remotion": "tsc --noEmit -p tsconfig.remotion.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "remotion:studio": "remotion studio remotion/index.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@google/generative-ai": "^0.24.1",
    "@remotion/bundler": "4.0.466",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "electron-store": "8.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "4.22.3",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
